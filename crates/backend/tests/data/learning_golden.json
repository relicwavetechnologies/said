{
  "_doc": "Hand-labelled golden set for the learning pipeline. Each case is exercised against the deterministic stages (pre_filter + diff + promotion_gate) and, when run with --features live-eval and GROQ_API_KEY, also the LLM classifier. See crates/backend/tests/learning_eval.rs for the runner.",
  "_label_keys": {
    "pre_filter": "drop | early_user_rewrite | early_user_rephrase | pass",
    "expected_class": "STT_ERROR | POLISH_ERROR | USER_REPHRASE | USER_REWRITE | DROP",
    "should_promote_term": "exact correct_form expected to survive promotion gates, or null if no promotion expected",
    "promotion_should_pass": "true if promotion gates would accept (assuming the LLM hands them this term)",
    "notes": "free text"
  },
  "cases": [
    {
      "name": "no-op same text",
      "polish": "hello world",
      "user_kept": "hello world",
      "transcript": "hello world",
      "output_language": "english",
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "identical strings should never reach the LLM"
      }
    },
    {
      "name": "whitespace normalization only",
      "polish": "hello world",
      "user_kept": "  hello   world  ",
      "transcript": "hello world",
      "output_language": "english",
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "whitespace-only normalisation is not a learnable edit"
      }
    },
    {
      "name": "n8n in-place fix",
      "polish": "I use written for automation",
      "user_kept": "I use n8n for automation",
      "transcript": "I use written for automation",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "n8n",
        "promotion_should_pass": true,
        "notes": "canonical jargon STT-error case"
      }
    },
    {
      "name": "k8s in-place fix (consonant-heavy short jargon)",
      "polish": "running k aids in production",
      "user_kept": "running k8s in production",
      "transcript": "running k aids in production",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "k8s",
        "promotion_should_pass": true,
        "notes": "should pass jargon_score gate"
      }
    },
    {
      "name": "Anis -> anish (1-char tail extension)",
      "polish": "Anis sent the email",
      "user_kept": "anish sent the email",
      "transcript": "Anis sent the email",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "anish",
        "promotion_should_pass": true,
        "notes": "must NOT be flagged as concatenation pattern (only 1 char extra)"
      }
    },
    {
      "name": "EMIAC concatenation guard (pre-filter catches first)",
      "polish": "MAAR is here for review",
      "user_kept": "EMIACMAAR is here for review",
      "transcript": "MAAR is here for review",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "EMIACMAAR",
        "promotion_should_pass": false,
        "notes": "polish appears as suffix of one token. Concatenation guard must reject. Length is below 1.4x threshold so pre-filter must NOT catch it."
      }
    },
    {
      "name": "polish error reverted to STT word",
      "polish": "I will kindly send it",
      "user_kept": "I will please send it",
      "transcript": "I will please send it",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "POLISH_ERROR",
        "should_promote_term": "please",
        "promotion_should_pass": true,
        "notes": "user reverted polish word back to original transcript"
      }
    },
    {
      "name": "pure rephrase synonym swap",
      "polish": "the meeting was good",
      "user_kept": "the meeting was great",
      "transcript": "the meeting was good",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "USER_REPHRASE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "common synonym should not be learned"
      }
    },
    {
      "name": "full rewrite",
      "polish": "short note",
      "user_kept": "this is a totally different sentence rewritten from scratch",
      "transcript": "short note",
      "output_language": "english",
      "expected": {
        "pre_filter": "early_user_rewrite",
        "expected_class": "USER_REWRITE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "1.4x growth catches in pre_filter"
      }
    },
    {
      "name": "markdown link prefix wrap",
      "polish": "Anish at Gmail dot com ka zara batana kaun sa mail ID par bhejna hai",
      "user_kept": "[anish@gmail.com](mailto:anish@gmail.com) Anish at Gmail dot com ka zara batana kaun sa mail ID par bhejna hai",
      "transcript": "Anish at Gmail dot com ka zara batana kaun sa mail ID par bhejna hai",
      "output_language": "hinglish",
      "expected": {
        "pre_filter": "early_user_rewrite",
        "expected_class": "USER_REWRITE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "polish kept verbatim with markdown link prefix"
      }
    },
    {
      "name": "Devanagari override in hinglish mode",
      "polish": "main kal jaunga",
      "user_kept": "मैं कल जाऊंगा",
      "transcript": "main kal jaunga",
      "output_language": "hinglish",
      "expected": {
        "pre_filter": "early_user_rephrase",
        "expected_class": "USER_REPHRASE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "user overrode Roman polish into Devanagari while pref is hinglish — not learnable"
      }
    },
    {
      "name": "Devanagari leak rejected by promotion gate even if classifier passed",
      "polish": "main kal jaunga",
      "user_kept": "main kal jaunga",
      "transcript": "main kal jaunga",
      "output_language": "english",
      "_synthetic_promotion": {
        "transcript_form": "main",
        "correct_form": "मैं"
      },
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": "मैं",
        "promotion_should_pass": false,
        "notes": "even if LLM hallucinated Devanagari, promotion gate must reject for English mode"
      }
    },
    {
      "name": "URL preserved with no learnable change",
      "polish": "see https://said.app for more",
      "user_kept": "see https://said.app for more",
      "transcript": "see said.app for more",
      "output_language": "english",
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "no diff between polish and kept"
      }
    },
    {
      "name": "punctuation-only edit",
      "polish": "Hello, world.",
      "user_kept": "Hello world!",
      "transcript": "Hello world",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "USER_REPHRASE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "punctuation-only edits should not produce learnable hunks"
      }
    },
    {
      "name": "case-only acronym fix iphone -> iPhone",
      "polish": "I bought an iphone yesterday",
      "user_kept": "I bought an iPhone yesterday",
      "transcript": "I bought an iphone yesterday",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "iPhone",
        "promotion_should_pass": true,
        "notes": "case-fix should be learnable; iPhone has mixed case so jargon_score passes"
      }
    },
    {
      "name": "snake_case identifier",
      "polish": "use the get_user_id function",
      "user_kept": "use the get_user_id function",
      "transcript": "use the get user ID function",
      "output_language": "english",
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "polish already produced the right form"
      }
    },
    {
      "name": "Hindi mode with mixed Roman jargon (n8n) is learnable",
      "polish": "main n8n use karta hun",
      "user_kept": "main n8n use karta hun",
      "transcript": "main written use karta hun",
      "output_language": "hindi",
      "expected": {
        "pre_filter": "drop",
        "expected_class": "DROP",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "no edit needed; pipeline drops"
      }
    },
    {
      "name": "Anish in Hinglish (Roman jargon)",
      "polish": "anees ne mail bhejna hai",
      "user_kept": "Anish ne mail bhejna hai",
      "transcript": "anees ne mail bhejna hai",
      "output_language": "hinglish",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "Anish",
        "promotion_should_pass": true,
        "notes": "Roman jargon in Hinglish mode — should learn"
      }
    },
    {
      "name": "double STT errors in same edit",
      "polish": "n a tin and aiden are tools",
      "user_kept": "n8n and Aiden are tools",
      "transcript": "n a tin and aiden are tools",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "n8n",
        "promotion_should_pass": true,
        "notes": "two corrections in one edit — at least one term should promote"
      }
    },
    {
      "name": "low-confidence keystroke_only capture",
      "polish": "the quick brown fox",
      "user_kept": "the quick brown n8n",
      "transcript": "the quick brown fox",
      "output_language": "english",
      "capture_method": "keystroke_only",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "n8n",
        "promotion_should_pass": false,
        "notes": "keystroke_only must not auto-promote regardless of class"
      }
    },
    {
      "name": "obvious typo writen -> written",
      "polish": "I had writen the doc",
      "user_kept": "I had written the doc",
      "transcript": "I had writen the doc",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "written",
        "promotion_should_pass": true,
        "notes": "phonetic triage should resolve this without LLM (same phon key, lev=1)"
      }
    },
    {
      "name": "case fix iphone -> iPhone via triage",
      "polish": "I bought an iphone",
      "user_kept": "I bought an iPhone",
      "transcript": "I bought an iphone",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "STT_ERROR",
        "should_promote_term": "iPhone",
        "promotion_should_pass": true,
        "notes": "phonetic triage resolves casing; jargon_score boosted by mixed case"
      }
    },
    {
      "name": "multi-word swap stays ambiguous (LLM territory)",
      "polish": "good morning everyone",
      "user_kept": "great morning everyone",
      "transcript": "good morning everyone",
      "output_language": "english",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "USER_REPHRASE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "synonym swap that could be either rephrase or polish-error — LLM disambiguates"
      }
    },
    {
      "name": "Hindi mode allows Devanagari learning",
      "polish": "main kal jaunga",
      "user_kept": "मैं कल जाऊंगा",
      "transcript": "main kal jaunga",
      "output_language": "hindi",
      "expected": {
        "pre_filter": "pass",
        "expected_class": "USER_REPHRASE",
        "should_promote_term": null,
        "promotion_should_pass": false,
        "notes": "in Hindi mode the script-mismatch pre-filter is permissive but the LLM will class as REPHRASE because user just changed scripts"
      }
    }
  ]
}
